# ============ API KEYS ============
# Gemini FREE tier (aistudio.google.com) — ALL text, vision, embeddings, search
# grounding run here at $0.00. Required for the pipeline to be free.
GOOGLE_API_KEY=

# OpenAI — used ONLY for gpt-image-1 image generation (the $10 budget) and as a
# gpt-4o-mini text lifeline if Gemini rate-limits mid-demo (~$0.001/call).
OPENAI_API_KEY=

# Seedance (BytePlus ModelArk) — OPTIONAL. Only used when you explicitly click
# "Generate video" on a /bundle creative (~$0.30 per 5s/720p clip). Leave empty
# to get the ready-to-run video prompt instead of a rendered video.
SEEDANCE_API_KEY=

# ============ GUARDRAILS ============
DEMO_MODE=true              # true: image gen falls back to /cache on any API failure or cap
MAX_IMAGE_CALLS_PER_RUN=6   # hard cap on paid image calls per creative run

# ============ PERSISTENCE ============
# Point this at the Railway Volume mount (e.g. /data) in production.
# Locally it defaults to adpipeline/data. Holds SQLite DB, Chroma index, images, video.
DATA_DIR=

# ============ PROVIDER / MODEL OVERRIDES (all optional) ============
# IMAGE_PROVIDER=openai       # openai (gpt-image-2, best ad quality) | gemini (free tier drafts)
# IMAGE_MODEL=gpt-image-2
# GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# GEMINI_MODEL=gemini-3.5-flash          # ALL text-in/text-out tasks
# GEMINI_MODEL_LITE=gemini-3.5-flash     # copy blocks (split to a cheaper id if desired)
# GEMINI_SEARCH_MODEL=gemini-2.5-flash   # google_search grounding ONLY
# EMBED_PROVIDER=gemini       # gemini (free) | openai (cap-immune retrieval, ~$0.0003/corpus).
#                             # Switching auto re-embeds (provider is in the corpus fingerprint) —
#                             # no manual chroma deletion. All text/vision already fall back to
#                             # gpt-4o-mini when the Gemini free tier caps; this frees the LAST
#                             # Gemini dependency (embeddings) too, if you want RAG fully cap-proof.
# SEEDANCE_MODEL=seedance-1-0-lite-t2v-250428
# SEEDANCE_BASE_URL=https://ark.ap-southeast.bytepluses.com/api/v3
# SEEDANCE_RESOLUTION=720p
# SEEDANCE_DURATION_S=5
# SEEDANCE_COST_PER_VIDEO=0.30

# Option B only: set to a Railway Postgres URL to move metadata off SQLite.
DATABASE_URL=

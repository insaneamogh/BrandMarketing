OPENAI_API_KEY=
GOOGLE_API_KEY=
DEMO_MODE=true              # true: image gen falls back to /cache on any API failure or cap
MAX_IMAGE_CALLS_PER_RUN=6

# Persistence — point this at the Railway Volume mount (e.g. /data) in production.
# Locally it defaults to adpipeline/data. Holds SQLite DB, Chroma index, images.
DATA_DIR=

# Optional model overrides (env so you can change ids without a code change)
IMAGE_MODEL=gpt-image-1
GEMINI_MODEL=gemini-2.0-flash

# Option B only: set to a Railway Postgres URL to move metadata off SQLite.
DATABASE_URL=
